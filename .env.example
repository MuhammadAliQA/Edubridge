DEBUG=True
SECRET_KEY=change-me
# For local dev you can leave DATABASE_URL empty to use SQLite (db.sqlite3).
# For production (Render), set DATABASE_URL to your PostgreSQL connection string.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
ALLOWED_HOSTS=*
# CSRF trusted origins (comma-separated), e.g. https://your-domain.com
CSRF_TRUSTED_ORIGINS=
# Optional: set to True to force DATABASE_URL (production safety)
REQUIRE_DATABASE_URL=False
# Security (production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
REFERRER_POLICY=same-origin
# Optional: set to True to skip reading local .env from disk
SKIP_DOTENV=False
# Optional: move admin off /admin/ in production
# ADMIN_PATH=secure-admin/

# Manual payment (no integration)
PAYMENT_CARD_NUMBER=
PAYMENT_CARD_OWNER=
PAYMENT_PHONE=
PAYMENT_TELEGRAM=
